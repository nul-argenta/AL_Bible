{
    "name": "armor-light",
    "version": "0.1.0",
    "type": "module",
    "license": "MIT",
    "main": "dist/electron/main.cjs",
    "description": "Armor & Light Bible Study App",
    "author": "ArmorLight",
    "scripts": {
        "dev": "cross-env NODE_ENV=development tsx server/start.ts",
        "build": "vite build && esbuild server/start.ts --platform=node --bundle --external:better-sqlite3 --external:electron --format=cjs --outfile=dist/start.cjs && esbuild electron/main.ts --platform=node --packages=external --bundle --format=cjs --outfile=dist/electron/main.cjs",
        "start": "cross-env NODE_ENV=production node dist/start.cjs",
        "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5000 && electron .\"",
        "dist": "npm run build && node scripts/obfuscate.cjs && electron-builder",
        "postinstall": "electron-builder install-app-deps",
        "check": "tsc",
        "db:push": "drizzle-kit push",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage"
    },
    "build": {
        "afterPack": "scripts/afterPack.cjs",
        "appId": "com.armorlight.app",
        "productName": "Armor & Light",
        "buildDependenciesFromSource": true,
        "npmRebuild": true,
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "client/public/**/*",
            "data/**/*",
            "package.json"
        ],
        "asarUnpack": [
            "dist/start.cjs",
            "dist/public/**/*",
            "node_modules/better-sqlite3/**/*",
            "node_modules/bindings/**/*",
            "node_modules/file-uri-to-path/**/*"
        ],
        "extraResources": [
            {
                "from": "data",
                "to": "data",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "client/public/icon.png"
        }
    },
    "dependencies": {
        "@clerk/clerk-react": "^5.61.2",
        "@clerk/clerk-sdk-node": "^4.13.23",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@google/genai": "^1.43.0",
        "@hookform/resolvers": "^3.10.0",
        "@radix-ui/react-accordion": "^1.2.4",
        "@radix-ui/react-alert-dialog": "^1.1.7",
        "@radix-ui/react-aspect-ratio": "^1.1.7",
        "@radix-ui/react-avatar": "^1.1.4",
        "@radix-ui/react-checkbox": "^1.1.5",
        "@radix-ui/react-collapsible": "^1.1.11",
        "@radix-ui/react-context-menu": "^2.2.15",
        "@radix-ui/react-dialog": "^1.1.7",
        "@radix-ui/react-dropdown-menu": "^2.1.7",
        "@radix-ui/react-hover-card": "^1.1.7",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-menubar": "^1.1.15",
        "@radix-ui/react-navigation-menu": "^1.2.13",
        "@radix-ui/react-popover": "^1.1.7",
        "@radix-ui/react-progress": "^1.1.3",
        "@radix-ui/react-radio-group": "^1.3.7",
        "@radix-ui/react-scroll-area": "^1.2.4",
        "@radix-ui/react-select": "^2.1.7",
        "@radix-ui/react-separator": "^1.1.3",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.2.0",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.4",
        "@radix-ui/react-toast": "^1.2.7",
        "@radix-ui/react-toggle": "^1.1.9",
        "@radix-ui/react-toggle-group": "^1.1.10",
        "@radix-ui/react-tooltip": "^1.2.0",
        "@tanstack/react-query": "^5.60.5",
        "@types/leaflet": "^1.9.21",
        "bcryptjs": "^3.0.3",
        "better-sqlite3": "^12.8.0",
        "better-sqlite3-session-store": "^0.1.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "concurrently": "^9.1.2",
        "date-fns": "^3.6.0",
        "drizzle-orm": "^0.39.1",
        "drizzle-zod": "^0.7.0",
        "embla-carousel-react": "^8.6.0",
        "express": "^4.21.2",
        "express-session": "^1.18.2",
        "framer-motion": "^11.13.1",
        "input-otp": "^1.4.2",
        "leaflet": "^1.9.4",
        "lucide-react": "^0.453.0",
        "memorystore": "^1.6.7",
        "next-themes": "^0.4.6",
        "openai": "^6.21.0",
        "passport": "^0.7.0",
        "passport-local": "^1.0.0",
        "react": "^18.3.1",
        "react-day-picker": "^8.10.1",
        "react-dom": "^18.3.1",
        "react-hook-form": "^7.55.0",
        "react-markdown": "^10.1.0",
        "react-resizable-panels": "^2.1.7",
        "react-router-dom": "^6.30.1",
        "recharts": "^2.15.4",
        "remark-gfm": "^4.0.1",
        "sonner": "^1.7.4",
        "strongs": "^1.0.2",
        "tailwind-merge": "^2.6.0",
        "tailwindcss-animate": "^1.0.7",
        "vaul": "^0.9.9",
        "wait-on": "^8.0.2",
        "wouter": "^3.3.5",
        "zod": "^3.24.2",
        "zustand": "^5.0.9"
    },
    "devDependencies": {
        "@replit/vite-plugin-runtime-error-modal": "^0.0.3",
        "@tailwindcss/typography": "^0.5.15",
        "@tailwindcss/vite": "^4.1.3",
        "@types/bcryptjs": "^2.4.6",
        "@types/better-sqlite3": "^7.6.13",
        "@types/express": "4.17.21",
        "@types/express-session": "^1.18.2",
        "@types/node": "20.16.11",
        "@types/passport": "^1.0.17",
        "@types/passport-local": "^1.0.38",
        "@types/react": "^18.3.11",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.7.0",
        "autoprefixer": "^10.4.20",
        "cross-env": "^10.1.0",
        "drizzle-kit": "^0.31.4",
        "electron": "^34.2.0",
        "electron-builder": "^25.1.8",
        "esbuild": "^0.25.0",
        "javascript-obfuscator": "^5.3.0",
        "lovable-tagger": "^1.1.13",
        "postcss": "^8.4.47",
        "tailwindcss": "^3.4.17",
        "tsx": "^4.20.5",
        "typescript": "5.6.3",
        "vite": "^5.4.20",
        "vitest": "^4.0.18"
    }
}